# .env.example
# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Model Configuration
MODEL_PATH=models/sentiment-model
MODEL_NAME=bert-base-uncased

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=sentiment-analysis

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Data Configuration
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed

# S3 Configuration
S3_BUCKET=nlp-sentiment-models
S3_PREFIX=models

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
